! Input script for Charmm generated by 'Charmm_manager'.

dimension chsize 999999
bomlev -2
read rtf card name "/net/work/jones/Karlsberg3/benchmarking/test/top_c36/top.inp" 
read rtf card name "/net/work/jones/Karlsberg3/benchmarking/test/top_c36/converted_0.rtf" append
read rtf card name "/net/work/jones/Karlsberg3/benchmarking/test/top_c36/converted_1.rtf" append
read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/par.inp" 
read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/converted_0.prm" append
read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/converted_1.prm" append
read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/toppar_water_ions.str" append
read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/par_all36m_prot_additions.prm" append
read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/backfill.prm" append


read sequence coor name "1jbb_stripped_in_A.crd" resid 
generate setup A first ACE last CT1

read coor card name "1jbb_stripped_in_A.crd"

hbuild sele segid A .and. hydrogen end

ic para
ic build

hbuild sele segid A .and. hydrogen end

ic para
ic build

coor print sele segid A .and. .not. INIT end

read sequence coor name "1jbb_stripped_in_B.crd" resid 
generate setup B first ACE last CT1

read coor card name "1jbb_stripped_in_B.crd" resid

hbuild sele segid B .and. hydrogen end

ic para
ic build

hbuild sele segid B .and. hydrogen end

ic para
ic build

coor print sele segid B .and. .not. INIT end




ic para
ic build

hbuild

NBONDS EPS 10
define sel_1 select (segid A .and. resid 6 .and. type CG) .or. (segid A .and. resid 6 .and. type CD) -
               .or. (segid A .and. resid 6 .and. type CE) .or. (segid A .and. resid 6 .and. type NZ) -
               .or. (segid A .and. resid 31 .and. type CG) .or. (segid A .and. resid 31 .and. type OD1) -
               .or. (segid A .and. resid 31 .and. type ND2) .or. (segid A .and. resid 36 .and. type CG) -
               .or. (segid A .and. resid 36 .and. type CD) .or. (segid A .and. resid 36 .and. type OE1) -
               .or. (segid A .and. resid 36 .and. type NE2) .or. (segid A .and. resid 82 .and. type CG) -
               .or. (segid A .and. resid 82 .and. type CD) .or. (segid A .and. resid 82 .and. type NE) -
               .or. (segid A .and. resid 82 .and. type CZ) .or. (segid A .and. resid 82 .and. type NH1) -
               .or. (segid A .and. resid 82 .and. type NH2) .or. (segid A .and. resid 128 .and. type CG) -
               .or. (segid A .and. resid 128 .and. type OD1) .or. (segid A .and. resid 128 .and. type OD2) -
               .or. (segid A .and. resid 150 .and. type CG) .or. (segid A .and. resid 150 .and. type CD) -
               .or. (segid A .and. resid 150 .and. type CE) .or. (segid A .and. resid 150 .and. type NZ) -
               .or. (segid B .and. resid 6 .and. type CG) .or. (segid B .and. resid 6 .and. type CD) -
               .or. (segid B .and. resid 6 .and. type CE) .or. (segid B .and. resid 6 .and. type NZ) -
               .or. (segid B .and. resid 10 .and. type CG) .or. (segid B .and. resid 10 .and. type CD) -
               .or. (segid B .and. resid 10 .and. type CE) .or. (segid B .and. resid 10 .and. type NZ) -
               .or. (segid B .and. resid 121 .and. type CG) .or. (segid B .and. resid 121 .and. type CD1) -
               .or. (segid B .and. resid 121 .and. type CD2) end
cons fix select .not. ( sel_1 .or. (type OE*)  .or. (type OD*)  .or. hydrogens )   end
minimize sd nsteps 1000 tolg 0.1
minimize abnr nsteps 5000 tolg 0.01

ioformat exten
write coord pdb name "1jbb_stripped_out.pdb"
write coord card name "1jbb_stripped_out.crd"
write psf card name "1jbb_stripped_out.psf"
write psf xplor card name "1jbb_stripped_out.xplor.psf"

stop
