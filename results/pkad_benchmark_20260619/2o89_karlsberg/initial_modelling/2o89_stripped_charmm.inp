read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/par_all36m_prot_additions.prm" append
read para card flex name "/net/work/jones/Karlsberg3/benchmarking/test/par_c36/backfill.prm" append


read sequence coor name "2o89_stripped_in_A.crd" resid 
generate setup A first ACE last CTER

read coor card name "2o89_stripped_in_A.crd"

hbuild sele segid A .and. hydrogen end

ic para
ic build

hbuild sele segid A .and. hydrogen end

ic para
ic build

coor print sele segid A .and. .not. INIT end




ic para
ic build

hbuild

NBONDS EPS 10
define sel_1 select (segid A .and. resid 5 .and. type CD) .or. (segid A .and. resid 5 .and. type CE) -
               .or. (segid A .and. resid 5 .and. type NZ) .or. (segid A .and. resid 33 .and. type CG) -
               .or. (segid A .and. resid 33 .and. type CD) .or. (segid A .and. resid 33 .and. type CE) -
               .or. (segid A .and. resid 33 .and. type NZ) .or. (segid A .and. resid 41 .and. type CG) -
               .or. (segid A .and. resid 41 .and. type CD) .or. (segid A .and. resid 41 .and. type OE1) -
               .or. (segid A .and. resid 41 .and. type OE2) .or. (segid A .and. resid 47 .and. type CG) -
               .or. (segid A .and. resid 47 .and. type CD) .or. (segid A .and. resid 47 .and. type OE1) -
               .or. (segid A .and. resid 47 .and. type OE2) .or. (segid A .and. resid 49 .and. type CG) -
               .or. (segid A .and. resid 49 .and. type CD) .or. (segid A .and. resid 49 .and. type CE) -
               .or. (segid A .and. resid 49 .and. type NZ) .or. (segid A .and. resid 54 .and. type NZ) -
               .or. (segid A .and. resid 59 .and. type CD) .or. (segid A .and. resid 59 .and. type OE1) -
               .or. (segid A .and. resid 59 .and. type OE2) .or. (segid A .and. resid 71 .and. type OG) -
               .or. (segid A .and. resid 79 .and. type NZ) .or. (segid A .and. resid 86 .and. type NZ) -
               .or. (segid A .and. resid 93 .and. type CD) .or. (segid A .and. resid 93 .and. type CE) -
               .or. (segid A .and. resid 93 .and. type NZ) .or. (segid A .and. resid 94 .and. type OE1) -
               .or. (segid A .and. resid 94 .and. type OE2) .or. (segid A .and. resid 98 .and. type CD) -
               .or. (segid A .and. resid 98 .and. type OE1) .or. (segid A .and. resid 98 .and. type OE2) -
               .or. (segid A .and. resid 102 .and. type CD) .or. (segid A .and. resid 102 .and. type CE) -
               .or. (segid A .and. resid 102 .and. type NZ) end
cons fix select .not. ( sel_1 .or. (type OE*)  .or. (type OD*)  .or. hydrogens )   end
minimize sd nsteps 1000 tolg 0.1
minimize abnr nsteps 5000 tolg 0.01

ioformat exten
write coord pdb name "2o89_stripped_out.pdb"
write coord card name "2o89_stripped_out.crd"
write psf card name "2o89_stripped_out.psf"
